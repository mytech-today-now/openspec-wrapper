# .env.example — OpenSpec AI Agent configuration template
# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Supported values: anthropic | openai | ollama
# Tool calling requires the Anthropic Messages API; other providers fall back to
# Anthropic automatically with a warning.
AI_PROVIDER=anthropic

# ── Model ────────────────────────────────────────────────────────────────────
# Leave blank to use the provider's recommended default (claude-3-5-sonnet-latest).
# Examples: claude-3-5-sonnet-latest  claude-3-opus-latest  gpt-4o
AI_MODEL=

# ── API Key ──────────────────────────────────────────────────────────────────
# Required for all providers except ollama.
# Anthropic keys start with sk-ant-  |  OpenAI keys start with sk-
AI_API_KEY=your-api-key-here

# ── Base URL (optional) ───────────────────────────────────────────────────────
# Override the provider endpoint — useful for proxies or self-hosted models.
# Leave blank to use the provider's default endpoint.
# AI_BASE_URL=https://api.anthropic.com

# ── Sampling Temperature ─────────────────────────────────────────────────────
# Float 0.0–1.0. Lower = more deterministic. Default: 0.2
AI_TEMPERATURE=0.2

# ── Max ReAct Iterations ─────────────────────────────────────────────────────
# Maximum think→act→observe cycles before the agent exits gracefully.
# Default: 10. Increase for complex multi-step tasks.
AI_MAX_ITERATIONS=10

# ── OpenSpec Working Directory ───────────────────────────────────────────────
# Absolute path to the repo where openspec commands are executed.
# Default: the directory the agent process is launched from (process.cwd()).
# OPENSPEC_CWD=/path/to/your/project

# ── Debug Mode ───────────────────────────────────────────────────────────────
# Set to "true" to print full LLM request/response payloads to stderr.
# Useful for inspecting token flow. Default: false
DEBUG=false

