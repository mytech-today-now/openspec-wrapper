# npm registry configuration for @mytech-today-now scoped packages
# GitHub Packages — requires a Personal Access Token with packages:write scope
# Set NODE_AUTH_TOKEN in your environment before running `npm publish`:
#   $env:NODE_AUTH_TOKEN = "ghp_your_token_here"   (PowerShell)
#   export NODE_AUTH_TOKEN=ghp_your_token_here      (bash/zsh)
@mytech-today-now:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}

